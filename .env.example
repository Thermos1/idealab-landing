# Public — baked into HTML at build time (visible in browser source)
PUBLIC_SIPMIND_API_BASE=https://sipmind.net
# Create a dedicated widget-only API key for tenant 0001 in SIPmind Dashboard → Account → API Keys.
# DO NOT reuse the Admin key — widget key is for /api/v1/widget/* only.
PUBLIC_SIPMIND_API_KEY=
PUBLIC_SITE_URL=https://www.allergoscreen.kz

# Server-side — never exposed to browser
# Lead notification bot (reuse LEAD_NOTIFY_TELEGRAM_BOT_TOKEN from SIPmind Coolify)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=-5103750900

# JSONL leads on Coolify persistent volume (/data mount)
LEADS_DIR=/data/leads

# Astro server
HOST=0.0.0.0
PORT=4321
NODE_ENV=production
