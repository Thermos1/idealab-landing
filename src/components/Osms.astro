---
import { t, type Locale } from "../i18n/ui";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const s = t(locale);

function lp(target: string): string {
  if (locale === "ru") return target;
  return `/${locale}${target === "/" ? "" : target}`;
}
---

<!-- HERO -->
<section class="relative bg-ink-900 text-white overflow-hidden">
  <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full bg-gold/10 blur-3xl"></div>
  <div class="container-x py-16 lg:py-24 relative">
    <a href={lp("/")} class="text-[13px] text-white/55 hover:text-gold inline-flex items-center gap-1 mb-6">{s.common.back_home}</a>
    <div class="inline-flex items-center gap-2 text-[12px] uppercase tracking-[0.16em] font-bold text-gold mb-4">
      <span class="h-1.5 w-1.5 rounded-full bg-gold"></span>
      {s.osms_band.eyebrow}
    </div>
    <h1 class="text-white mb-5 max-w-narrow">{s.osms_page.title}</h1>
    <p class="text-white/75 text-[18px] md:text-[20px] leading-relaxed max-w-prose">{s.osms_page.lede}</p>
  </div>
</section>

<!-- COVERED -->
<section class="container-x py-16 lg:py-20">
  <h2 class="mb-10 lg:mb-12 max-w-narrow reveal">{s.osms_page.covered_title}</h2>
  <div class="grid md:grid-cols-3 gap-4 lg:gap-6">
    {
      s.osms_page.covered_items.map((it, i) => (
        <div class="reveal card p-6 lg:p-8 relative overflow-hidden">
          <div class="absolute top-0 right-0 text-[80px] font-display font-extrabold text-brand-50 leading-none pointer-events-none">{i + 1}</div>
          <div class="relative">
            <div class="text-[11px] uppercase tracking-[0.16em] font-bold text-brand-700 mb-2">{it.code}</div>
            <h3 class="mb-3">{it.name}</h3>
            <p class="text-ink-600 text-[14.5px] leading-relaxed">{it.description}</p>
          </div>
        </div>
      ))
    }
  </div>
</section>

<!-- FLOW -->
<section class="bg-mist border-y border-rule py-16 lg:py-24">
  <div class="container-x">
    <h2 class="mb-10 lg:mb-12 max-w-narrow reveal">{s.osms_page.flow_title}</h2>
    <div class="space-y-4 lg:space-y-5 max-w-3xl">
      {
        s.osms_page.flow_steps.map((step) => (
          <div class="reveal card p-6 lg:p-7 flex gap-5 lg:gap-6">
            <div class="flex-shrink-0">
              <div class="h-12 w-12 lg:h-14 lg:w-14 rounded-xl bg-brand text-white inline-flex items-center justify-center font-display font-bold text-lg lg:text-xl">
                {step.n}
              </div>
            </div>
            <div>
              <h3 class="text-[18px] lg:text-[20px] mb-2">{step.title}</h3>
              <p class="text-ink-600 text-[15px] leading-relaxed">{step.body}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- NOT COVERED -->
<section class="container-x py-16 lg:py-20">
  <div class="card p-8 lg:p-10 reveal">
    <h3 class="mb-4">{s.osms_page.not_covered_title}</h3>
    <p class="text-ink-600 text-[16px] leading-relaxed mb-6 max-w-prose">{s.osms_page.not_covered_body}</p>
    <a href={lp("/services")} class="btn-primary">{s.osms_page.cta}</a>
  </div>
</section>

<!-- CTA -->
<section class="container-x pb-16 lg:pb-24">
  <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-brand-600 via-brand to-brand-400 text-white p-8 sm:p-12 reveal">
    <div class="absolute inset-0 bg-grid opacity-15"></div>
    <div class="relative max-w-narrow">
      <div class="eyebrow !text-white/80 mb-3">{s.contact_cta.eyebrow}</div>
      <h2 class="text-white mb-4">{s.contact_cta.title}</h2>
      <p class="text-white/85 text-[17px] leading-relaxed max-w-prose mb-6">{s.contact_cta.body}</p>
      <div class="flex flex-wrap gap-3">
        <button type="button" id="osms-chat" class="btn-gold">{s.contact_cta.cta_chat}</button>
        <a href="tel:+77024786568" class="btn-ghost !bg-white">{s.contact_cta.cta_call}</a>
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById("osms-chat")?.addEventListener("click", () => {
    (document.getElementById("sm-toggle") as HTMLButtonElement | null)?.click();
  });
</script>
