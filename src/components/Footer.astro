---
import { t, type Locale } from "../i18n/ui";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const s = t(locale);

function lp(target: string): string {
  if (locale === "ru") return target;
  return `/${locale}${target === "/" ? "" : target}`;
}

const year = new Date().getFullYear();

// Brand strings — verbatim from idealab.kz footer
const ru = locale === "ru";
const companyLabel = ru ? "Компания" : "Компания";
const companyName = "ТОО «НИИ Аллергоскрин»";
const legalAddrLabel = ru ? "Адрес" : "Мекенжай";
const legalAddr = ru
  ? "г. Астана, ул. генерал С.Рақымов, 22"
  : "Астана қ., генерал С.Рақымов к-сі, 22";
const socialsLabel = ru ? "Социальные сети" : "Әлеуметтік желілер";
const pagesLabel = ru ? "Страницы" : "Беттер";
---

<footer class="bg-ink-900 text-white/85 mt-24">
  <div class="container-x py-14 lg:py-16">
    <!-- Top: brand + tagline + Bregis CTA -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-12">
      <div>
        <a href={lp("/")} class="inline-flex items-center gap-3">
          <img
            src="/brand/logo-mark-256.png"
            srcset="/brand/logo-mark-256.png 1x, /brand/logo-mark-512.png 2x"
            alt="IdeaLab"
            width="80"
            height="43"
            class="h-12 w-auto bg-white rounded-lg p-1.5 shadow-sm"
          />
          <span class="font-display font-bold text-[22px] tracking-tight text-white">IdeaLab.kz</span>
        </a>
        <p class="mt-4 max-w-prose text-white/65 text-[15px] leading-relaxed">{s.footer.tagline}</p>
      </div>
      <a
        href={lp("/results")}
        class="btn-gold inline-flex w-full sm:w-auto justify-center"
      >
        {s.nav.results_cta}
      </a>
    </div>

    <!-- 3 columns: Pages / Company / Socials (idealab.kz pattern) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12">
      <!-- Pages -->
      <div>
        <h4 class="text-white font-display font-semibold text-base mb-4">{pagesLabel}</h4>
        <ul class="space-y-2.5 text-[14px]">
          <li><a href={lp("/")} class="text-white/65 hover:text-brand-300">{s.nav.home}</a></li>
          <li><a href={lp("/services")} class="text-white/65 hover:text-brand-300">{s.nav.services}</a></li>
          <li><a href={lp("/locations")} class="text-white/65 hover:text-brand-300">{s.nav.locations}</a></li>
          <li><a href={lp("/license")} class="text-white/65 hover:text-brand-300">{ru ? "Лицензия" : "Лицензия"}</a></li>
          <li><a href="/offer" class="text-white/65 hover:text-brand-300">{ru ? "Публичная оферта" : "Жария оферта"}</a></li>
          <li><a href="/preparation" class="text-white/65 hover:text-brand-300">{ru ? "Подготовка" : "Дайындық"}</a></li>
        </ul>
      </div>

      <!-- Company info — verbatim from idealab.kz footer -->
      <div>
        <h4 class="text-white font-display font-semibold text-base mb-4">{companyLabel}</h4>
        <div class="text-[14px] text-white/65 leading-relaxed space-y-1">
          <div class="text-white">{companyName}</div>
          <div><span class="text-white/45">{legalAddrLabel}:</span> {legalAddr}</div>
          <div class="pt-3">
            <a href="tel:+77004286568" class="text-white hover:text-brand-300 block">+7 (700) 428-65-68</a>
            <a href="https://wa.me/77759893287" target="_blank" rel="noopener" class="text-white hover:text-brand-300 block">+7 (775) 989-32-87 <span class="text-white/45 text-[12px]">WhatsApp</span></a>
            <a href="mailto:idealab.nii@gmail.com" class="text-white/65 hover:text-brand-300 block mt-1">idealab.nii@gmail.com</a>
          </div>
        </div>
      </div>

      <!-- Socials -->
      <div>
        <h4 class="text-white font-display font-semibold text-base mb-4">{socialsLabel}</h4>
        <p class="text-[13.5px] text-white/55 mb-3 leading-relaxed">
          {ru ? "Подпишитесь и следите за новостями в наших социальных сетях" : "Жазылыңыз және әлеуметтік желілеріміздегі жаңалықтарды бақылаңыз"}
        </p>
        <ul class="space-y-2.5 text-[14px]">
          <li>
            <a href="https://www.instagram.com/idealab.nii" target="_blank" rel="noopener" class="text-white/65 hover:text-brand-300 inline-flex items-center gap-2">
              Instagram 
            </a>
          </li>
          <li>
            <a href="https://www.youtube.com/@IdeaLab_nii" target="_blank" rel="noopener" class="text-white/65 hover:text-brand-300 inline-flex items-center gap-2">
              YouTube 
            </a>
          </li>
          <li>
            <a href="https://wa.me/77759893287" target="_blank" rel="noopener" class="text-white/65 hover:text-brand-300 inline-flex items-center gap-2">
              WhatsApp 
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom: copyright + БИН -->
    <div class="mt-14 pt-6 border-t border-white/10 flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between text-[12px] text-white/45 leading-relaxed">
      <div>© {year} {companyName} · БИН 211140010036</div>
      <div class="sm:text-right">{ru ? "Все права защищены" : "Барлық құқықтар қорғалған"}</div>
    </div>
  </div>
</footer>
