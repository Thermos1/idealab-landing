---
// Homepage sections shared across all 3 locales.
import { t, type Locale } from "../i18n/ui";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const s = t(locale);

function lp(target: string): string {
  if (locale === "ru") return target;
  return `/${locale}${target === "/" ? "" : target}`;
}

// Inline SVG icons — kept here so we don't ship a sprite for ~10 icons
const icons = {
  shield: '<svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>',
  flask: '<svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v6L5 18a4 4 0 0 0 4 6h6a4 4 0 0 0 4-6L14 8V2"/><path d="M8 2h8"/><path d="M7 16h10"/></svg>',
  certificate: '<svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="9" r="6"/><path d="m9 13.5-2 8 5-3 5 3-2-8"/><path d="m9 9 2 2 4-4"/></svg>',
  microscope: '<svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 18h8"/><path d="M3 22h18"/><path d="M14 22a7 7 0 1 0 0-14h-1"/><path d="M9 14h2"/><path d="M9 12v6"/><path d="M9 2l2 2-2 2-2-2z"/><path d="M7 4h4"/></svg>',
  pill: '<svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="m10.5 20.5 10-10a4.95 4.95 0 1 0-7-7l-10 10a4.95 4.95 0 1 0 7 7Z"/><path d="m8.5 8.5 7 7"/></svg>',
  drop: '<svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>',
  sparkle: '<svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18M3 12h18M5.6 5.6l12.8 12.8M18.4 5.6 5.6 18.4"/></svg>',
  spray: '<svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="10" width="12" height="12" rx="2"/><path d="M9 10V7a3 3 0 0 1 6 0v3"/><path d="M3 4h2M3 8h2M3 12h2M3 6h2"/></svg>',
  apple: '<svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 7c-2 0-2 2-4 2s-3-2-3-5c0 0 4-1 7 3"/><path d="M12 7c2 0 2 2 4 2s3-2 3-5c0 0-4-1-7 3"/><path d="M5 12c0-3 3-5 7-5s7 2 7 5c0 6-3 10-7 10s-7-4-7-10z"/></svg>',
  leaf: '<svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 4 13a7 7 0 0 1 7-7c4 0 6 2 9 0-1 3-3 4-3 8 0 4-3 6-6 6z"/><path d="M2 22c2-5 5-8 11-10"/></svg>',
  paw: '<svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="4" cy="14" r="2"/><circle cx="20" cy="16" r="2"/><path d="M8 22a5 5 0 0 1-5-5 5 5 0 0 1 5-5h8a5 5 0 0 1 5 5 5 5 0 0 1-5 5z"/></svg>',
  dna: '<svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 2c2 6 16 6 16 14M4 22c2-6 16-6 16-14"/><path d="M5 5h2M9 5h2M13 5h2M17 5h2M5 9h2M9 9h2M13 9h2M17 9h2M5 15h2M9 15h2M13 15h2M17 15h2M5 19h2M9 19h2M13 19h2M17 19h2"/></svg>',
  pin: '<svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 7-8 13-8 13s-8-6-8-13a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>',
  clock: '<svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
  phone: '<svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>',
  chat: '<svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>',
};

const serviceIconKeys = [
  "microscope", "pill", "drop", "spray", "sparkle", "apple", "leaf", "paw", "dna",
] as const;
---

<!-- ========================================================================== -->
<!-- HERO -->
<!-- ========================================================================== -->
<section class="relative overflow-hidden bg-mist">
  <div class="absolute inset-0 bg-grid bg-grid-fade opacity-70 pointer-events-none"></div>
  <div class="absolute top-0 right-0 -translate-y-1/4 translate-x-1/4 w-[600px] h-[600px] rounded-full bg-brand-100/40 blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 translate-y-1/3 -translate-x-1/4 w-[500px] h-[500px] rounded-full bg-gold-50 blur-3xl pointer-events-none"></div>

  <div class="container-x relative pt-12 pb-16 lg:pt-20 lg:pb-24">
    <div class="max-w-narrow">
      <!-- Left -->
      <div class="reveal">
        <div class="eyebrow mb-5 inline-flex items-center gap-2 bg-white px-3 py-1.5 rounded-full border border-brand-100">
          <span class="h-1.5 w-1.5 rounded-full bg-brand"></span>
          {s.hero.eyebrow}
        </div>
        <h1 class="break-words">
          {s.hero.h1_lead} <span class="text-crimson-500">{s.hero.h1_accent}</span><span class="text-ink-400 font-medium block mt-1 text-[22px] sm:text-3xl md:text-4xl lg:text-[44px] leading-snug" style="letter-spacing: -0.01em;">— {s.hero.h1_tail}</span>
        </h1>
        <p class="lede mt-6">{s.hero.lede}</p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href={lp("/services")} class="btn-primary">
            {s.hero.cta_primary}
            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.4">
              <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <button type="button" id="hero-chat-cta" class="btn-ghost">
            <span class="inline-flex h-4 w-4" set:html={icons.chat} />
            {s.hero.cta_secondary}
          </button>
        </div>

      </div>

      </div>
  </div>
</section>

<!-- ========================================================================== -->
<!-- QUICK LINKS (4 cards from idealab.kz home) -->
<!-- ========================================================================== -->
<section class="container-x -mt-10 lg:-mt-14 relative z-10">
  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-5">
    <a href={lp("/services")} class="reveal card-hover p-6 lg:p-7 flex gap-4 group bg-white">
      <div class="h-11 w-11 rounded-lg bg-brand-50 text-brand-700 inline-flex items-center justify-center flex-shrink-0">
        <span class="inline-flex h-5 w-5" set:html={icons.flask} />
      </div>
      <div>
        <h3 class="text-[17px] mb-1 group-hover:text-brand-700 transition">{locale === "ru" ? "Список анализов" : "Талдаулар тізімі"}</h3>
        <p class="text-ink-600 text-[13.5px] leading-relaxed">{locale === "ru" ? "Перечень выполняемых исследований лаборатории." : "Зертхана орындайтын зерттеулердің тізбесі."}</p>
      </div>
    </a>
    <a href={lp("/locations")} class="reveal card-hover p-6 lg:p-7 flex gap-4 group bg-white">
      <div class="h-11 w-11 rounded-lg bg-brand-50 text-brand-700 inline-flex items-center justify-center flex-shrink-0">
        <span class="inline-flex h-5 w-5" set:html={icons.pin} />
      </div>
      <div>
        <h3 class="text-[17px] mb-1 group-hover:text-brand-700 transition">{locale === "ru" ? "Пункты забора" : "Қан алу пункттері"}</h3>
        <p class="text-ink-600 text-[13.5px] leading-relaxed">{locale === "ru" ? "Пункты забора на карте и контакты." : "Қан алу пункттері картада және байланыс."}</p>
      </div>
    </a>
    <button type="button" id="quicklink-chat" class="reveal card-hover p-6 lg:p-7 flex gap-4 group bg-white text-left">
      <div class="h-11 w-11 rounded-lg bg-brand-50 text-brand-700 inline-flex items-center justify-center flex-shrink-0">
        <span class="inline-flex h-5 w-5" set:html={icons.chat} />
      </div>
      <div>
        <h3 class="text-[17px] mb-1 group-hover:text-brand-700 transition">{locale === "ru" ? "Написать нам" : "Бізге жазу"}</h3>
        <p class="text-ink-600 text-[13.5px] leading-relaxed">{locale === "ru" ? "Возникли вопросы? Напишите нам в WhatsApp." : "Сұрақтарыңыз бар ма? WhatsApp арқылы бізге жазыңыз."}</p>
      </div>
    </button>
    <a href={lp("/results")} class="reveal card-hover p-6 lg:p-7 flex gap-4 group bg-white">
      <div class="h-11 w-11 rounded-lg bg-brand-50 text-brand-700 inline-flex items-center justify-center flex-shrink-0">
        <span class="inline-flex h-5 w-5" set:html={icons.certificate} />
      </div>
      <div>
        <h3 class="text-[17px] mb-1 group-hover:text-brand-700 transition">{locale === "ru" ? "Получить результаты" : "Нәтижелерді алу"}</h3>
        <p class="text-ink-600 text-[13.5px] leading-relaxed">{locale === "ru" ? "Переходите в личный кабинет и смотрите анализы онлайн." : "Жеке кабинетке өтіп, талдаулардың нәтижелерін онлайн қараңыз."}</p>
      </div>
    </a>
  </div>
</section>

<!-- ========================================================================== -->
<!-- USP -->
<!-- ========================================================================== -->
<section class="container-x py-16 lg:py-24">
  <h2 class="reveal max-w-narrow">{s.usp.title}</h2>
  <div class="mt-10 lg:mt-12 grid sm:grid-cols-2 gap-4 lg:gap-6">
    {
      s.usp.items.map((item, i) => {
        const iconKey = (["shield", "certificate", "flask"] as const)[i];
        return (
          <div class="reveal card p-6 lg:p-7 flex gap-5">
            <div class="flex-shrink-0">
              <div class="h-11 w-11 rounded-lg bg-brand-50 text-brand-700 inline-flex items-center justify-center">
                <span class="inline-flex h-5 w-5" set:html={icons[iconKey]} />
              </div>
            </div>
            <div>
              <h3 class="text-[18px] mb-2">{item.title}</h3>
              <p class="text-ink-600 text-[15px] leading-relaxed">{item.body}</p>
            </div>
          </div>
        );
      })
    }
  </div>
</section>



<!-- ========================================================================== -->
<!-- TECHNOLOGY -->
<!-- ========================================================================== -->
<section class="container-x py-16 lg:py-24">
  <div class="max-w-narrow mb-10 lg:mb-14 reveal">
    <div class="eyebrow mb-3">{s.tech.eyebrow}</div>
    <h2 class="mb-4">{s.tech.title}</h2>
    <p class="lede">{s.tech.lede}</p>
  </div>

  <div class="grid md:grid-cols-3 gap-4 lg:gap-6">
    {
      [s.tech.imasa, s.tech.alex, s.tech.aia].map((tech, i) => (
        <div class="reveal relative overflow-hidden">
          <div class="card p-7 lg:p-8 h-full">
            <div class="text-[11px] uppercase tracking-[0.16em] font-bold text-brand-700 mb-3">
              {String(i + 1).padStart(2, "0")}
            </div>
            <h3 class="text-[22px] mb-1.5">{tech.title}</h3>
            <p class="text-brand-700 text-[13px] font-semibold mb-4">{tech.tagline}</p>
            <p class="text-ink-600 text-[14.5px] leading-relaxed">{tech.body}</p>
          </div>
        </div>
      ))
    }
  </div>
</section>



<!-- ========================================================================== -->
<!-- LOCATIONS PREVIEW -->
<!-- ========================================================================== -->
<section class="container-x py-16 lg:py-24">
  <div class="max-w-narrow mb-10 lg:mb-14 reveal">
    <div class="eyebrow mb-3">{s.locations_preview.eyebrow}</div>
    <h2 class="mb-4">{s.locations_preview.title}</h2>
    <p class="lede">{s.locations_preview.lede}</p>
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-5">
    {
      s.locations_preview.cities.map((c) => {
        const photoMap = {
          astana: { src: "/photos/astana-baitursynova-600.jpg", src2x: "/photos/astana-baitursynova-1200.jpg" },
          almaty: { src: "/photos/almaty-seifullina-600.jpg", src2x: "/photos/almaty-seifullina-1200.jpg" },
          karaganda: { src: "/photos/karaganda-stepnoy-600.jpg", src2x: "/photos/karaganda-stepnoy-1200.jpg" },
          temirtau: { src: "/photos/temirtau-mira-600.jpg", src2x: "/photos/temirtau-mira-1200.jpg" },
        };
        const p = photoMap[c.slug as keyof typeof photoMap];
        return (
          <a href={lp(`/locations#${c.slug}`)} class="card-hover group flex flex-col reveal overflow-hidden">
            <div class="aspect-[4/3] bg-ink-900 relative overflow-hidden">
              <img
                src={p.src}
                srcset={`${p.src} 1x, ${p.src2x} 2x`}
                alt={`Филиал IdeaLab в ${c.city}`}
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="p-6 flex-1 flex flex-col">
              <h3 class="text-[20px] mb-3 text-ink-900">{c.city}</h3>
              <ul class="space-y-1.5 text-[13.5px] text-ink-600 mb-4">
                {c.addresses.map((a) => <li>{a}</li>)}
              </ul>
              <div class="mt-auto space-y-2 pt-4 border-t border-rule">
                <div class="text-[13px] text-ink-400 inline-flex items-center gap-2">
                  <span class="inline-flex h-4 w-4" set:html={icons.clock} />
                  {c.hours}
                </div>
                <div class="text-[13.5px] font-semibold text-brand-700 inline-flex items-center gap-2">
                  <span class="inline-flex h-4 w-4" set:html={icons.phone} />
                  {c.phone_label}
                </div>
              </div>
            </div>
          </a>
        );
      })
    }
  </div>

  <div class="mt-10 lg:mt-12 text-center reveal">
    <a href={lp("/locations")} class="btn-ghost">{s.locations_preview.cta}</a>
  </div>
</section>



<!-- ========================================================================== -->
<!-- CONTACT CTA -->
<!-- ========================================================================== -->
<section class="relative">
  <div class="container-x">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-brand-600 via-brand to-brand-400 text-white p-8 sm:p-12 lg:p-16 reveal">
      <div class="absolute inset-0 bg-grid opacity-15"></div>
      <div class="relative grid lg:grid-cols-[1.4fr_1fr] gap-8 items-center">
        <div>
          <div class="eyebrow !text-white/80 mb-3">{s.contact_cta.eyebrow}</div>
          <h2 class="text-white mb-4">{s.contact_cta.title}</h2>
          <p class="text-white/85 text-[17px] leading-relaxed max-w-prose">{s.contact_cta.body}</p>
        </div>
        <div class="flex flex-col sm:flex-row lg:flex-col gap-3 lg:items-stretch">
          <button id="cta-chat" type="button" class="btn-gold lg:w-full justify-center">
            <span class="inline-flex h-4 w-4" set:html={icons.chat} />
            {s.contact_cta.cta_chat}
          </button>
          <a href="tel:+77004286568" class="btn-ghost !bg-white lg:w-full justify-center">
            <span class="inline-flex h-4 w-4" set:html={icons.phone} />
            {s.contact_cta.cta_call}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Wire hero + final CTA chat buttons to open the SIPmind widget
  function openWidget() {
    const toggle = document.getElementById("sm-toggle");
    if (toggle) (toggle as HTMLButtonElement).click();
  }
  document.getElementById("hero-chat-cta")?.addEventListener("click", openWidget);
  document.getElementById("cta-chat")?.addEventListener("click", openWidget);
  document.getElementById("quicklink-chat")?.addEventListener("click", openWidget);
</script>
