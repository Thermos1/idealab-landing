---
import { t, type Locale } from "../i18n/ui";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const s = t(locale).testimonials;

// 4 video testimonials from patients (vertical phone clips, with consent).
const videos = [
  { src: "/videos/testimonial-1.mp4", id: "t1" },
  { src: "/videos/testimonial-2.mp4", id: "t2" },
  { src: "/videos/testimonial-3.mp4", id: "t3" },
  { src: "/videos/testimonial-4.mp4", id: "t4" },
];
---

<section class="bg-mist border-y border-rule py-16 lg:py-24">
  <div class="container-x">
    <div class="max-w-narrow mb-10 lg:mb-12 reveal">
      <div class="eyebrow mb-3">{s.eyebrow}</div>
      <h2 class="mb-4">{s.title}</h2>
      <p class="lede">{s.lede}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-5">
      {
        videos.map((v) => (
          <div class="reveal relative rounded-2xl overflow-hidden bg-ink-900 shadow-card" style="aspect-ratio: 9 / 16;">
            <video
              id={v.id}
              src={v.src}
              preload="metadata"
              playsinline
              controls
              class="w-full h-full object-cover bg-ink-900"
              aria-label={s.play_label}
            />
          </div>
        ))
      }
    </div>

    <p class="mt-6 text-[12.5px] text-ink-400 leading-relaxed reveal">{s.consent_note}</p>
  </div>
</section>
