---
import Base from "../layouts/Base.astro";
---

<Base locale="ru" title="Заявка принята — IdeaLab">
  <section class="container-x py-20 lg:py-32 text-center">
    <div class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-brand-50 text-brand-700 mb-8">
      <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
        <polyline points="20 6 9 17 4 12" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </div>
    <h1 class="mb-5">Заявка принята</h1>
    <p class="lede mx-auto mb-10">
      Мы получили ваше сообщение и свяжемся с вами в ближайшее рабочее время — обычно в течение часа в часы работы колл-центра (08:00–20:00 по времени Астаны).
    </p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a href="/" class="btn-primary">На главную</a>
      <a href="/services" class="btn-ghost">Перейти к анализам</a>
    </div>
  </section>
</Base>
